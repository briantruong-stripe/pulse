# ── Required ──────────────────────────────────────────────────────────────────
PORT=3000
DASHBOARD_KEY=stripe-atr-2026

# ── Google Sheets (replaces local JSON in production) ─────────────────────────
# 1. Create a Google Cloud service account with Sheets API enabled
# 2. Download the JSON key and paste its entire contents (minified) here
# 3. Share your Google Sheet with the service account email (Editor role)
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"pulse@your-project.iam.gserviceaccount.com",...}

# The spreadsheet ID — found in the URL: docs.google.com/spreadsheets/d/[THIS_PART]/edit
GOOGLE_SHEETS_ID=1abc123xyz...

# ── Salesforce (optional — enables opportunity dropdown and pipeline report) ───
SFDC_LOGIN_URL=https://login.salesforce.com
SFDC_USERNAME=your.email@stripe.com
SFDC_PASSWORD=yourpassword
SFDC_SECURITY_TOKEN=yourtoken
# Your Salesforce instance URL for direct opp links (e.g. https://stripe.lightning.force.com)
SFDC_INSTANCE_URL=https://your-instance.lightning.force.com
